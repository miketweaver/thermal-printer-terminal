# Thermal Printer Terminal - Configuration
# Copy to .env and customize for your station

# Printer connection
PRINTER_HOST=printer.local.mesh
PRINTER_PORT=9100
PRINTER_TIMEOUT=5
PRINTER_RETRY_MAX=2

# Printer features
ENABLE_CUT=true
PAPER_WIDTH_CHARS=48

# Station identity
NODE_CALLSIGN=NOCALL
SERVER_HOST=

# Security — CHANGE THESE before deploying
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-random-string

# Database
DATABASE_PATH=data/printqueue.db

# Rate limiting
RATE_LIMIT_PRINTS=10/minute
MAX_QUEUE_SIZE=100
MAX_MESSAGE_LENGTH=1000

# App
APP_VERSION=1.0.0
